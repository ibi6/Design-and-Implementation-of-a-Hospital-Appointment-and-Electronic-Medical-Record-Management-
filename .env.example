# Copy this file to .env and replace every production credential.
# Never commit the resulting .env file.

# Backend
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod
APP_JWT_SECRET=replace-with-at-least-32-random-bytes
APP_JWT_EXPIRE_HOURS=72
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
APP_COOKIE_SECURE=false
APP_COOKIE_SAME_SITE=Lax
APP_MAX_LOGIN_FAILURES=5
APP_LOGIN_FAILURE_WINDOW_MINUTES=15
APP_MAX_TRACKED_USERNAMES=10000
APP_DEMO_DATA_ENABLED=false

# MySQL
MYSQL_DATABASE=hospital
MYSQL_USER=hospital_app
MYSQL_PASSWORD=replace-with-a-strong-database-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-root-password
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/hospital?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
SPRING_DATASOURCE_USERNAME=hospital_app
SPRING_DATASOURCE_PASSWORD=replace-with-a-strong-database-password

# Frontend
WEB_PORT=8088
